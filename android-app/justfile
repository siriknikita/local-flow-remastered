# LocalFlow — task runner

# Default recipe: list available commands
default:
    @just --list

# — Build ——————————————————————————————————————————

# Build debug APK (copies path to clipboard on macOS)
[group('build')]
build *args:
    #!/bin/bash
    set -e
    echo "=== Building LocalFlow (debug) ==="
    ./gradlew assembleDebug {{args}}
    APK_PATH="$(pwd)/app/build/outputs/apk/debug/app-debug.apk"
    osascript -e "set the clipboard to POSIX file \"$APK_PATH\""
    echo "=== Build successful — APK copied to clipboard ==="

# Build release APK (copies path to clipboard on macOS)
[group('build')]
release *args:
    #!/bin/bash
    set -e
    echo "=== Building LocalFlow (release) ==="
    ./gradlew assembleRelease {{args}}
    APK_PATH="$(pwd)/app/build/outputs/apk/release/app-release.apk"
    osascript -e "set the clipboard to POSIX file \"$APK_PATH\""
    echo "=== Release build successful — APK copied to clipboard ==="

# Clean build artifacts
[group('build')]
clean *args:
    ./gradlew clean {{args}}

# — Test ———————————————————————————————————————————

# Run unit tests
[group('test')]
test *args:
    ./gradlew testDebugUnitTest {{args}}

# Run Android instrumented tests (requires device)
[group('test')]
test-android *args:
    ./gradlew connectedDebugAndroidTest {{args}}

# Run lint check
[group('test')]
lint *args:
    ./gradlew lintDebug {{args}}
    @echo "Report: app/build/reports/lint-results-debug.html"

# Run all checks (build + test + lint)
[group('test')]
check: build test lint

# — Deploy —————————————————————————————————————————

# Build and install wirelessly (main dev command)
[group('deploy')]
deploy *args:
    adeploy {{args}}

# Connect to device over wireless ADB (usage: just connect [port])
[group('deploy')]
connect *args:
    adeploy connect {{args}}

# Disconnect wireless ADB
[group('deploy')]
disconnect:
    adeploy disconnect

# Pair with device for wireless debugging (one-time)
[group('deploy')]
pair port code:
    adeploy pair {{port}} {{code}}

# Build and install via adb install (use ANDROID_SERIAL env or -s flag if multiple devices)
[group('deploy')]
install: build
    adb -s $(adb devices | grep -v 'List' | head -1 | awk '{print $1}') install -r app/build/outputs/apk/debug/app-debug.apk
